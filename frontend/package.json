{
  "name": "interface-frontend",
  "version": "1.0.0",
  "description": "Import temeljnica — frontend (Electron + React)",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dist": "vite build && electron-builder --win",
    "dist:portable": "vite build && set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win --config electron-builder-portable.json"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.iti.interface",
    "productName": "ITI Interface",
    "asar": false,
    "win": {
      "target": "dir"
    },
    "files": [
      "electron/**/*",
      "dist/**/*"
    ]
  }
}
